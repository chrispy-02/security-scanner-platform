# ─────────────────────────────────────────────────────────────────────────────
# Vulnerability Detect and Analysis — example environment file
# Copy to `.env` (root, used by docker-compose) and/or `Web_app/.env` (local runs).
# NEVER commit a real .env. All values below are placeholders.
# Any secret that was previously committed to this project is COMPROMISED and must
# be rotated by the owner (see SECURITY.md).
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask ────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-me-generate-a-long-random-hex
# production | development  (production disables debug + enables secure cookies)
FLASK_ENV=production
# Bind port for the web server
PORT=8080
# Public base URL of the deployed app (used for OAuth redirect; leave blank locally)
APP_BASE_URL=

# ── MySQL ────────────────────────────────────────────────────────────────────
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=scanner
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=vulnscan
# Root password used only by the local docker-compose MySQL service
MYSQL_ROOT_PASSWORD=change-me-root
# Set to "true" inside containers so the app reads real env instead of a .env file
DOCKER_ENV=true

# ── Application crypto (rotate these; defaults must not be reused publicly) ───
# Fernet key for reversible session-email encryption.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-generate-a-fernet-key
# Salt for one-way password/api-key hashing (any random string; reseed demo users after change)
PASSWORD_SALT=change-me-random-salt

# ── Google OAuth (optional; demo login works without it) ─────────────────────
OAUTH_ID=
OAUTH_SECRET=

# ── GitHub Actions scan backend (optional; live scans disabled if unset) ─────
# Fine-grained PAT with Actions read/write on the repo below.
GITHUB_TOKEN=
GITHUB_OWNER=your-github-username
GITHUB_REPO=security-scanner-platform
GITHUB_WORKFLOW_FILE=zap-scan.yml
GITHUB_REF=main

# ── Demo mode ────────────────────────────────────────────────────────────────
# When true: seeds demo users and may restrict open registration / destructive writes.
DEMO_MODE=true
DEMO_OWNER_PASSWORD=demo-owner-pass
DEMO_ADMIN_PASSWORD=demo-admin-pass
DEMO_EMPLOYEE_PASSWORD=demo-employee-pass
DEMO_READER_PASSWORD=demo-reader-pass

# ── Scan safety ──────────────────────────────────────────────────────────────
# Comma-separated hostnames demo users are allowed to scan. Owner/admin bypass the list.
SCAN_ALLOWLIST=juice-shop.herokuapp.com,brokencrystals.com,testphp.vulnweb.com,scanme.nmap.org
# Minimum seconds between scans per user (0 disables)
SCAN_COOLDOWN_SECONDS=120
